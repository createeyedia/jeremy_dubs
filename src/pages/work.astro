---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  ['/img/paradise-finance-thumb.jpg','Web Design','Paradise Finance'],
  ['/img/allstar-after.jpg','Web Design','All Star Lake Spa'],
  ['/img/cascade-pest-case.jpg','Video','Cascade Pest Control'],
  ['https://vumbnail.com/316959450.jpg','Video','Silver Cloud Hotels'],
  ['/img/montessori-still-1.jpg','Brand Film','NW Montessori'],
  ['https://vumbnail.com/287757023.jpg','Real Estate','Bellevue Towers'],
  ['https://vumbnail.com/242191741.jpg','Real Estate','SAMM Apartments'],
  ['https://vumbnail.com/851990318.jpg','Drone','Medina Real Estate'],
  ['https://vumbnail.com/285677156.jpg','Social','Likewise — Social Ad'],
  ['https://vumbnail.com/275434535.jpg','Event','Riviera Rendezvous'],
  ['https://vumbnail.com/95992532.jpg','Video','Brewe Layman Law'],
  ['https://vumbnail.com/104476318.jpg','Event','Kind Snacks — CHBP'],
  ['/img/cascade-pest-still-2.jpg','Video','Cascade Pest — Seattle'],
  ['https://vumbnail.com/75112064.jpg','Brand Film','686 — Lights Out'],
  ['https://vumbnail.com/289601123.jpg','Brand Film','Likewise — Explainer'],
  ['https://vumbnail.com/835304479.jpg','Brand Film','10 Barrel Brewing'],
  ['https://vumbnail.com/242675538.jpg','Video','Karate West'],
];
---

<BaseLayout title="Work | Cascade Creatives" active="work">

<div class="page-hero">
  <div class="container">
    <p class="section-label animate-in">Portfolio</p>
    <h1 class="animate-in delay-1">Selected <em>Work</em></h1>
    <p class="hero-sub animate-in delay-2">Web design, video production, and content projects for businesses and brands.</p>
  </div>
</div>

<section>
  <div class="container">
    <div class="portfolio-grid">
      {projects.map(([src, type, name]) => (
        <div class="portfolio-item">
          <img src={src} alt={name} loading="lazy" />
          <div class="portfolio-overlay">
            <p class="type">{type}</p>
            <p class="name">{name}</p>
          </div>
        </div>
      ))}
    </div>
    <div style="text-align:center;margin-top:40px">
      <a href="https://vimeo.com/cascadecreatives" target="_blank" class="btn btn-ghost">View video reel on Vimeo &rarr;</a>
    </div>
  </div>
</section>

<section class="cta-section reveal">
  <div class="container">
    <h2 class="section-title">Want to work <em>together?</em></h2>
    <p class="section-sub">Tell us about your project and let&rsquo;s figure out the right approach.</p>
    <a href="/contact" class="btn btn-primary">Start a Project &rarr;</a>
  </div>
</section>

</BaseLayout>
