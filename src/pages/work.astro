---
import BaseLayout from '../layouts/BaseLayout.astro';

// [thumbnail, type, name, vimeoId or null]
const projects = [
  ['/img/paradise-finance-thumb.jpg','Web Design','Paradise Finance', null],
  ['/img/allstar-after.jpg','Web Design','All Star Lake Spa', null],
  ['/img/cascade-pest-case.jpg','Video','Cascade Pest Control', null],
  ['https://vumbnail.com/316959450.jpg','Video','Silver Cloud Hotels', '316959450'],
  ['/img/montessori-still-1.jpg','Brand Film','NW Montessori', null],
  ['https://vumbnail.com/287757023.jpg','Real Estate','Bellevue Towers', '287757023'],
  ['https://vumbnail.com/242191741.jpg','Real Estate','SAMM Apartments', '242191741'],
  ['https://vumbnail.com/851990318.jpg','Drone','Medina Real Estate', '851990318'],
  ['https://vumbnail.com/285677156.jpg','Social','Likewise — Social Ad', '285677156'],
  ['https://vumbnail.com/275434535.jpg','Event','Riviera Rendezvous', '275434535'],
  ['https://vumbnail.com/95992532.jpg','Video','Brewe Layman Law', '95992532'],
  ['https://vumbnail.com/104476318.jpg','Event','Kind Snacks — CHBP', '104476318'],
  ['/img/cascade-pest-still-2.jpg','Video','Cascade Pest — Seattle', null],
  ['https://vumbnail.com/75112064.jpg','Brand Film','686 — Lights Out', '75112064'],
  ['https://vumbnail.com/289601123.jpg','Brand Film','Likewise — Explainer', '289601123'],
  ['https://vumbnail.com/835304479.jpg','Brand Film','10 Barrel Brewing', '835304479'],
  ['https://vumbnail.com/242675538.jpg','Video','Karate West', '242675538'],
];
---

<BaseLayout title="Work | Cascade Creatives" active="work">

<div class="page-hero">
  <div class="container">
    <p class="section-label animate-in">Portfolio</p>
    <h1 class="animate-in delay-1">Selected <em>Work</em></h1>
    <p class="hero-sub animate-in delay-2">Web design, video production, and content projects for businesses and brands.</p>
  </div>
</div>

<section>
  <div class="container">
    <div class="portfolio-grid">
      {projects.map(([src, type, name, vimeoId]) => (
        <div class={`portfolio-item ${vimeoId ? 'has-video' : ''}`} data-vimeo={vimeoId || ''}>
          <img src={src as string} alt={name as string} loading="lazy" />
          <div class="portfolio-overlay">
            <p class="type">{type}</p>
            <p class="name">{name}</p>
          </div>
          {vimeoId && (
            <button class="play-btn" aria-label={`Play ${name}`}>
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="23" stroke="#c8ff00" stroke-width="2" fill="rgba(0,0,0,0.5)" />
                <polygon points="19,14 36,24 19,34" fill="#c8ff00" />
              </svg>
            </button>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<section class="cta-section reveal">
  <div class="container">
    <h2 class="section-title">Want to work <em>together?</em></h2>
    <p class="section-sub">Tell us about your project and let&rsquo;s figure out the right approach.</p>
    <a href="/contact" class="btn btn-primary">Start a Project &rarr;</a>
  </div>
</section>

</BaseLayout>
