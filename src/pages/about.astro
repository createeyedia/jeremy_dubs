---
import Base from '../layouts/Base.astro';

const facts = [
  { title: 'AI-Accelerated', desc: 'I use AI tools across every phase — research, design, development, content — to move faster without sacrificing quality.' },
  { title: '10+ Years in Production', desc: 'A decade of commercial video, brand films, and visual storytelling — now applied to web design and digital presence.' },
  { title: 'FAA Part 107 Licensed', desc: 'Licensed drone operator for aerial content — real estate, events, commercial projects.' },
  { title: 'Modern Stack', desc: 'Building on Astro, static HTML, and Webflow — fast, lightweight, and future-proof.' },
  { title: 'Design + Content', desc: 'I produce original photo and video content as part of the design process — not as an afterthought.' },
  { title: 'Cascade Creatives', desc: 'Operating as Cascade Creatives since 2013. Based in Bellingham, WA — working with clients everywhere.' },
];
---

<Base title="About — Jeremy Dubs | Cascade Creatives" description="I've spent a decade in visual storytelling and production. Now I combine that with modern web development and AI tools to build better digital presence — faster.">

  <section class="page-hero">
    <div class="container">
      <span class="label">About</span>
      <h1>Creative craft meets <em>modern tools.</em></h1>
      <p>I'm Jeremy Dubs — the designer, developer, and creative producer behind Cascade Creatives. I build websites, produce content, and help businesses show up better online.</p>
    </div>
  </section>

  <section>
    <div class="container" style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; align-items: start;">
      <div class="reveal">
        <img src="/img/jeremy-headshot.jpg" alt="Jeremy Dubs" style="border-radius: var(--radius); width: 100%;" />
      </div>
      <div class="reveal">
        <span class="label">The Short Version</span>
        <h2 style="margin: 0.5rem 0 1.5rem;">A decade of creative production, <em>now supercharged.</em></h2>
        <p style="color: var(--text-muted);">I started in video production — shooting commercials, brand films, real estate tours, and event coverage across the Pacific Northwest. Over time, clients needed more than just video. They needed better websites, stronger messaging, and a digital presence that matched the quality of their actual business.</p>
        <p style="color: var(--text-muted);">So I evolved. I taught myself modern web development, got deep into AI tools, and built a practice that combines <strong>design, content production, and strategic thinking</strong> into one offering. The result: I can design your site, produce the content for it, and deploy the whole thing — faster than a traditional agency, with more creative depth than a freelance developer.</p>
        <p style="color: var(--text-muted);">I don't run a bloated agency. When you work with me, you work <strong>directly with me</strong> — which means clearer communication, faster decisions, and work that actually reflects your vision.</p>
        <p style="color: var(--text-muted);">AI is a core part of how I work. I use it to accelerate research, development, content creation, and strategy — not to replace creative judgment, but to remove friction from the process. The output is better work, delivered faster.</p>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-elevated);">
    <div class="container">
      <div class="section-header reveal">
        <span class="label">What I Bring</span>
        <h2>Tools, experience, and <em>perspective.</em></h2>
      </div>
      <div class="facts-grid">
        {facts.map((f) => (
          <div class="fact-card reveal">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-block">
    <div class="container">
      <h2 class="reveal">Let's build something <em>together.</em></h2>
      <p style="color: var(--text-muted); margin-bottom: 2rem;" class="reveal">Tell me what you're working on and I'll help you figure out the best next step.</p>
      <a href="/contact" class="btn btn--primary reveal">Start a Project</a>
    </div>
  </section>
</Base>

<style>
  @media (max-width: 768px) {
    .container[style*="grid-template-columns: 1fr 1.5fr"] { grid-template-columns: 1fr !important; }
  }
</style>
