---
import Base from '../layouts/Base.astro';
const facts = [
  { title: 'AI-Accelerated', desc: 'We use AI tools across every phase — research, design, development, content — to move faster without sacrificing quality.' },
  { title: '10+ Years in Production', desc: 'Over a decade of commercial video, brand films, and visual storytelling — now applied to web design and digital strategy.' },
  { title: 'FAA Part 107 Licensed', desc: 'Licensed drone operators for aerial content — real estate, events, commercial projects.' },
  { title: 'Modern Stack', desc: 'Building on Astro, static HTML, and Webflow — fast, lightweight, and future-proof.' },
  { title: 'Design + Content', desc: 'We produce original photo and video content as part of the design process — not as an afterthought.' },
  { title: 'Since 2013', desc: 'Cascade Creatives has been serving businesses since 2013. Based in Bellingham, WA — working with clients everywhere.' },
];
---
<Base title="About | Cascade Creatives — Web Design, Content & Digital Strategy" description="Cascade Creatives is an AI-native creative studio specializing in web design, content production, and digital strategy. Founded by Jeremy Dubs.">
  <section class="page-hero"><div class="container"><span class="label">About</span><h1>Creative craft meets <em>modern tools.</em></h1><p><strong>Cascade Creatives</strong> is an AI-native creative studio that designs websites, produces content, and helps businesses build stronger digital presence. Founded by Jeremy Dubs — built on over a decade of creative production experience.</p></div></section>

  <section>
    <div class="container" style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; align-items: start;">
      <div class="reveal"><img src="/img/jeremy-headshot.jpg" alt="Jeremy Dubs — Founder, Cascade Creatives" style="border-radius: var(--radius); width: 100%;" /></div>
      <div class="reveal">
        <span class="label">The Story</span>
        <h2 style="margin: 0.5rem 0 1.5rem;">A decade of creative production, <em>now supercharged.</em></h2>
        <p style="color: var(--text-muted);">Cascade Creatives started in video production — shooting commercials, brand films, real estate tours, and event coverage. Over time, clients needed more than just video. They needed better websites, stronger messaging, and a digital presence that matched the quality of their actual business.</p>
        <p style="color: var(--text-muted);">So we evolved. We built a practice that combines <strong>modern web design, content production, and strategic thinking</strong> into one offering — powered by AI tools that let us move faster than traditional agencies while delivering more creative depth than a freelance developer.</p>
        <p style="color: var(--text-muted);">We don't operate like a bloated agency. When you work with Cascade Creatives, you work <strong>directly with the team doing the work</strong> — which means clearer communication, faster decisions, and results that actually reflect your vision.</p>
        <p style="color: var(--text-muted);">AI is a core part of how we work. We use it to accelerate research, development, content creation, and strategy — not to replace creative judgment, but to remove friction from the process. The output is better work, delivered faster.</p>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-elevated);">
    <div class="container">
      <div class="section-header reveal"><span class="label">What We Bring</span><h2>Tools, experience, and <em>perspective.</em></h2></div>
      <div class="facts-grid">{facts.map((f) => (<div class="fact-card reveal"><h3>{f.title}</h3><p>{f.desc}</p></div>))}</div>
    </div>
  </section>

  <section class="cta-block"><div class="container"><h2 class="reveal">Let's build something <em>together.</em></h2><p style="color: var(--text-muted); margin-bottom: 2rem;" class="reveal">Tell us what you're working on and we'll help figure out the best next step.</p><a href="/contact" class="btn btn--primary reveal">Start a Project</a></div></section>
</Base>
<style>@media (max-width: 768px) { .container[style*="grid-template-columns: 1fr 1.5fr"] { grid-template-columns: 1fr !important; } }</style>
