---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found | Jeremy Dubs">
  <section style="padding: 10rem 0; text-align: center;">
    <div class="container">
      <span class="label">404</span>
      <h1 style="margin: 1rem 0;">Page Not <em>Found</em></h1>
      <p style="color: var(--text-muted); max-width: 500px; margin: 0 auto 2rem;">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn--primary">Back to Home</a>
        <a href="/contact" class="btn btn--outline">Get in Touch</a>
      </div>
    </div>
  </section>
</Base>
