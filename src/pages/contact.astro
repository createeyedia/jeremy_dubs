---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Start a Project | Cascade Creatives" active="contact">

<div class="page-hero">
  <div class="container">
    <p class="section-label animate-in">Contact</p>
    <h1 class="animate-in delay-1">Let&rsquo;s talk about your <em>project.</em></h1>
    <p class="hero-sub animate-in delay-2">Tell us what you&rsquo;re working on — even if it&rsquo;s just a rough idea. We&rsquo;ll let you know how we can help and what a realistic next step looks like.</p>
  </div>
</div>

<section>
  <div class="container">
    <div class="contact-grid">
      <form action="https://formspree.io/f/xzdjkjrd" method="POST">
        <p style="font-size:.8rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-dim);margin-bottom:12px">What are you looking for?</p>
        <div class="service-select">
          <label><input type="checkbox" name="service[]" value="website" /><span>&#127760; New Website</span></label>
          <label><input type="checkbox" name="service[]" value="redesign" /><span>&#128260; Redesign</span></label>
          <label><input type="checkbox" name="service[]" value="content" /><span>&#127916; Content</span></label>
          <label><input type="checkbox" name="service[]" value="strategy" /><span>&#9889; Strategy</span></label>
        </div>
        <div class="form-group"><label>Your Name *</label><input type="text" name="name" required /></div>
        <div class="form-group"><label>Email Address *</label><input type="email" name="email" required /></div>
        <div class="form-group"><label>Company or Project Name</label><input type="text" name="company" /></div>
        <div class="form-group">
          <label>Budget Range</label>
          <select name="budget">
            <option value="">Select a range...</option>
            <option>Under $1,000</option>
            <option>$1,000 – $3,000</option>
            <option>$3,000 – $5,000</option>
            <option>$5,000 – $10,000</option>
            <option>$10,000+</option>
            <option>Not sure yet</option>
          </select>
        </div>
        <div class="form-group"><label>Tell us about your project *</label><textarea name="message" required></textarea></div>
        <button type="submit" class="btn btn-primary">Send Message &rarr;</button>
      </form>

      <div>
        <dl class="contact-details">
          <dt>Studio</dt><dd>Cascade Creatives</dd>
          <dt>Based in</dt><dd>Bellingham, WA</dd>
          <dt>Working with</dt><dd>Clients everywhere — remote-first</dd>
          <dt>Response Time</dt><dd>Within 1 business day</dd>
          <dt>Portfolio</dt><dd><a href="https://vimeo.com/cascadecreatives" target="_blank">vimeo.com/cascadecreatives</a></dd>
          <dt>Instagram</dt><dd><a href="https://www.instagram.com/cascadecreatives/" target="_blank">@cascadecreatives</a></dd>
        </dl>
        <div style="margin-top:32px;display:flex;gap:12px">
          <a href="/services" class="btn btn-ghost">View services</a>
          <a href="/work" class="btn btn-ghost">Browse portfolio</a>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
