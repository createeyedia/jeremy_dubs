---
import Base from '../layouts/Base.astro';
---

<Base
  title="Case Studies | Jeremy Dubs — Cascade Creatives"
  description="Detailed breakdowns of client work — what the problem was, what I did, and what changed. Video production and website upgrades."
>
  <section class="page-hero">
    <div class="container">
      <span class="label">Case Studies</span>
      <h1>Real Projects. Real <em>Results.</em></h1>
      <p>Detailed breakdowns of client work — what the problem was, what I did, and what changed.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 2rem;">
        <a href="#cascadepest" class="btn btn--outline">Cascade Pest Control</a>
        <a href="#allstar" class="btn btn--outline">All Star Lake Spa</a>
        <a href="#montessori" class="btn btn--outline">NW Montessori School</a>
        <a href="#marcel" class="btn btn--outline">Marcel Dolak — E&V</a>
      </div>
    </div>
  </section>

  <!-- ====== CASCADE PEST CONTROL ====== -->
  <section id="cascadepest">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Video Production</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Seattle / Western WA</span>
        </div>
        <h2>Cascade Pest Control — <em>Western Washington</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Brand Video</span>
          <span class="tag tag--accent">Social Reels</span>
          <span class="tag tag--accent">Commercials</span>
          <span class="tag tag--accent">Seasonal Campaigns</span>
          <span class="tag tag--accent">YouTube</span>
        </div>

        <h3 style="margin-top: 2rem;">The Work</h3>
        <p style="color: var(--text-muted);">Cascade Pest Control is a regional pest control company serving Seattle and Western Washington. They needed professional video content that kept them visible across platforms — commercials, social reels, seasonal campaigns, and YouTube content that matched the quality of their service.</p>
        <p style="color: var(--text-muted);">I handle everything from concept and scripting through filming, editing, and delivery — formatted for every platform they're on.</p>

        <h3 style="margin-top: 1.5rem;">What I Deliver</h3>
        <ul class="checklist" style="margin-top: 0.75rem;">
          <li>Brand commercials for web and paid media</li>
          <li>Short-form social reels for Instagram, TikTok, YouTube Shorts</li>
          <li>Seasonal campaign videos (spring pests, summer wasps, fall rodents, etc.)</li>
          <li>Long-form YouTube content</li>
          <li>Multiple edits per video: horizontal, vertical, 15s/30s/60s cuts</li>
          <li>On-location shoots across Western Washington</li>
          <li>Fast turnaround to align with seasonal timing</li>
        </ul>

        <div class="stats">
          <div class="stat"><span class="stat-value">Multi</span><span class="stat-label">Format Delivery</span></div>
          <div class="stat"><span class="stat-value">Multi</span><span class="stat-label">Platform Coverage</span></div>
          <div class="stat"><span class="stat-value">Year-Round</span><span class="stat-label">Seasonal Campaigns</span></div>
        </div>

        <div class="case-images">
          <img src="/img/cascade-pest-case.jpg" alt="Cascade Pest Control video production" loading="lazy" />
          <img src="/img/cascade-pest-still-2.jpg" alt="Cascade Pest Control on-location filming" loading="lazy" />
          <img src="/img/cascade-pest-still-3.jpg" alt="Cascade Pest Control social content" loading="lazy" />
        </div>

        <div class="testimonial">
          <blockquote>"Cascade Pest Control has partnered with Cascade Creatives on numerous video projects over the past few years. Jeremy always seeks to understand our vision to provide us with the best possible product."</blockquote>
          <cite>— Kevin Peterson, Operations Manager · Cascade Pest Control</cite>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width: var(--max-width-narrow); margin: 0 auto;"></div>

  <!-- ====== ALL STAR LAKE SPA ====== -->
  <section id="allstar">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Website Upgrade</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Bellevue, WA</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">~7 days</span>
        </div>
        <h2>All Star Lake Spa — <em>Bellevue, WA</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Homepage Rewrite</span>
          <span class="tag tag--accent">Spam Removal</span>
          <span class="tag tag--accent">Services Restructure</span>
          <span class="tag tag--accent">Mobile Fix</span>
          <span class="tag tag--accent">CTAs</span>
          <span class="tag tag--accent">Visual Redesign</span>
          <span class="tag tag--accent">Local SEO</span>
        </div>

        <!-- Before/After -->
        <div class="ba-slider" id="ba-slider-cs" style="margin: 2rem 0;">
          <img src="/img/allstar-before.jpg" alt="All Star Lake Spa — old site" class="ba-before" />
          <img src="/img/allstar-after.jpg" alt="All Star Lake Spa — redesigned" class="ba-after" />
          <div class="ba-handle" id="ba-handle-cs"></div>
        </div>

        <h3>The Situation</h3>
        <p style="color: var(--text-muted);">All Star Massage and Spa is a well-established lakeside spa in Bellevue, WA — 18+ years in business with a loyal client base and strong reputation. But their website had fallen far behind: the homepage was cluttered with outdated content, services were hard to find, and the mobile experience was broken.</p>
        <p style="color: var(--text-muted);">Worst of all, injected spam content had appeared on the services page — vaping and unrelated product spam that was actively harming their professional image and likely tanking their search rankings.</p>

        <h3 style="margin-top: 1.5rem;">What I Did</h3>
        <ul class="checklist" style="margin-top: 0.75rem;">
          <li>Removed injected vaping/spam content from the services page</li>
          <li>Rewrote the homepage headline and intro copy</li>
          <li>Restructured and simplified the entire services section</li>
          <li>Improved CTAs and the booking flow</li>
          <li>Cleaned up navigation and removed clutter</li>
          <li>Fixed mobile layout — tap targets, text sizing, spacing</li>
          <li>Visual redesign to match the actual quality of the spa</li>
          <li>Google Business alignment check</li>
        </ul>

        <div class="stats">
          <div class="stat"><span class="stat-value">100%</span><span class="stat-label">Spam Removed</span></div>
          <div class="stat"><span class="stat-value">New</span><span class="stat-label">Homepage Copy</span></div>
          <div class="stat"><span class="stat-value">Mobile</span><span class="stat-label">Fully Responsive</span></div>
        </div>

        <div class="testimonial">
          <blockquote>"The site finally reflects the quality of what we actually offer. Patients are finding us more easily and the booking flow actually works now."</blockquote>
          <cite>— Starla Schwartz, Owner · All Star Massage and Spa</cite>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width: var(--max-width-narrow); margin: 0 auto;"></div>

  <!-- ====== NW MONTESSORI ====== -->
  <section id="montessori">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Video Production — Anniversary Film</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Seattle, WA</span>
        </div>
        <h2>NW Montessori School — <em>60th Anniversary</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Anniversary Film</span>
          <span class="tag tag--accent">Archival Footage</span>
          <span class="tag tag--accent">Testimonials</span>
          <span class="tag tag--accent">Interviews</span>
          <span class="tag tag--accent">Fundraiser Screening</span>
        </div>

        <h3 style="margin-top: 2rem;">The Project</h3>
        <p style="color: var(--text-muted);">Northwest Montessori School came to us for their 60th anniversary fundraiser. They needed a video that captured the heart of the school's legacy — its people, philosophy, and sense of community — while being concise and impactful enough for a live event setting.</p>
        <p style="color: var(--text-muted);">The challenge: telling a 60-year story in 90 seconds, with limited time and a need to involve voices from across the school's entire history.</p>

        <h3 style="margin-top: 1.5rem;">The Approach</h3>
        <p style="color: var(--text-muted);">Instead of relying solely on traditional filming, we guided current and former students, teachers, and administrators to record personal reflections on their phones. We conducted key interviews with leadership — including the Head of School, Elizabeth, and former director, Jan. Then we wove in archival photos and school history to connect past and present.</p>

        <h3 style="margin-top: 1.5rem;">What We Delivered</h3>
        <ul class="checklist" style="margin-top: 0.75rem;">
          <li>90-second cinematic teaser optimized for live event presentation</li>
          <li>Creative direction and story development across three arcs: legacy, community, future</li>
          <li>Guided phone-recorded reflections from students, alumni, and staff</li>
          <li>Key interviews with school leadership</li>
          <li>Archival photo animation (Ken Burns) with clean transitions and warm grading</li>
          <li>Selected and refined impactful soundbites from multiple contributors</li>
          <li>Scalable foundation for a future long-form documentary version</li>
        </ul>

        <div class="stats">
          <div class="stat"><span class="stat-value">90s</span><span class="stat-label">Cinematic Teaser</span></div>
          <div class="stat"><span class="stat-value">60 Years</span><span class="stat-label">Of History Captured</span></div>
          <div class="stat"><span class="stat-value">Live</span><span class="stat-label">Event Screening</span></div>
        </div>

        <div class="case-images">
          <img src="/img/montessori-still-1.jpg" alt="NW Montessori 60th Anniversary film still" loading="lazy" />
          <img src="/img/montessori-still-2.jpg" alt="NW Montessori archival footage" loading="lazy" />
          <img src="/img/montessori-still-3.jpg" alt="NW Montessori community" loading="lazy" />
        </div>

        <div class="testimonial">
          <blockquote>"Jeremy and Melissa understood what we were trying to capture — not just our history, but the feeling of what this school means to our community. The film brought the room to tears at the fundraiser."</blockquote>
          <cite>— Elizabeth Truman, Head of School · NW Montessori School</cite>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width: var(--max-width-narrow); margin: 0 auto;"></div>

  <!-- ====== MARCEL DOLAK ====== -->
  <section id="marcel">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Real Estate Video</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Kirkland / Eastside / Seattle</span>
        </div>
        <h2>Marcel Dolak — <em>Engel & Völkers</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Listing Videos</span>
          <span class="tag tag--accent">Drone Aerial</span>
          <span class="tag tag--accent">Property Tours</span>
          <span class="tag tag--accent">Walkthrough</span>
          <span class="tag tag--accent">MLS Ready</span>
          <span class="tag tag--accent">Cinematic</span>
          <span class="tag tag--accent">Luxury Properties</span>
        </div>

        <h3 style="margin-top: 2rem;">The Partnership</h3>
        <p style="color: var(--text-muted);">Marcel Dolak is a seasoned luxury real estate agent with Engel & Völkers, owning the Kirkland office and co-owning locations in North Cascades Cle Elum, Bend, Sisters, and Palm Desert. He needed cinematic property videos that went beyond basic walkthrough footage — videos that made listings stand out in a competitive market and gave buyers a real sense of each space and setting.</p>
        <p style="color: var(--text-muted);">Working across properties in Medina, Bellevue, Kirkland, Magnolia, and the broader Eastside, each video combines smooth interior walkthroughs with aerial drone coverage and cinematic establishing shots — all edited to a luxury standard that matches Marcel's brand and the caliber of properties he represents.</p>

        <h3 style="margin-top: 1.5rem;">What I Delivered</h3>
        <ul class="checklist" style="margin-top: 0.75rem;">
          <li>Cinematic listing videos for luxury properties across WA</li>
          <li>FAA Part 107 licensed aerial drone coverage</li>
          <li>Smooth interior walkthrough footage</li>
          <li>Exterior establishing shots with cinematic grading</li>
          <li>Multiple formats: MLS, social, full-length</li>
          <li>Fast turnaround to meet listing timelines</li>
          <li>Consistent quality across multiple properties over time</li>
        </ul>

        <div class="stats">
          <div class="stat"><span class="stat-value">4K</span><span class="stat-label">Cinematic Quality</span></div>
          <div class="stat"><span class="stat-value">Part 107</span><span class="stat-label">Licensed Drone</span></div>
          <div class="stat"><span class="stat-value">Multi</span><span class="stat-label">Property Partnership</span></div>
        </div>

        <div class="testimonial">
          <blockquote>"Jeremy's listing videos consistently stand out. The aerial coverage and cinematic quality give my clients confidence and give buyers a reason to schedule a showing."</blockquote>
          <cite>— Marcel Dolak, Engel & Völkers Kirkland</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-block" style="background: var(--bg-elevated);">
    <div class="container">
      <h2 class="reveal">Ready for Results Like <em>These?</em></h2>
      <p style="color: var(--text-muted); margin-bottom: 2rem;" class="reveal">Tell me about your project. I'll tell you exactly what I'd do and what it would cost.</p>
      <a href="/contact" class="btn btn--primary reveal">Get in Touch</a>
    </div>
  </section>

  <!-- Before/After slider for this page -->
  <script>
    const slider = document.getElementById('ba-slider-cs');
    const handle = document.getElementById('ba-handle-cs');
    if (slider && handle) {
      let dragging = false;
      const move = (x: number) => {
        const rect = slider.getBoundingClientRect();
        let pct = ((x - rect.left) / rect.width) * 100;
        pct = Math.max(5, Math.min(95, pct));
        handle.style.left = pct + '%';
        const after = slider.querySelector('.ba-after') as HTMLElement;
        if (after) after.style.clipPath = `inset(0 0 0 ${pct}%)`;
      };
      slider.addEventListener('mousedown', (e) => { dragging = true; move(e.clientX); });
      window.addEventListener('mousemove', (e) => { if (dragging) move(e.clientX); });
      window.addEventListener('mouseup', () => { dragging = false; });
      slider.addEventListener('touchstart', (e) => { dragging = true; move(e.touches[0].clientX); }, { passive: false });
      slider.addEventListener('touchmove', (e) => { if (dragging) { e.preventDefault(); move(e.touches[0].clientX); } }, { passive: false });
      slider.addEventListener('touchend', () => { dragging = false; });
    }
  </script>
</Base>
