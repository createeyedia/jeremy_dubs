---
import Base from '../layouts/Base.astro';
---

<Base title="Case Studies | Jeremy Dubs — Cascade Creatives" description="Detailed breakdowns of client work — what the problem was, what I did, and what changed.">

  <section class="page-hero">
    <div class="container">
      <span class="label">Case Studies</span>
      <h1>Real projects. Real <em>results.</em></h1>
      <p>Detailed breakdowns of web design and content production work — the problem, the approach, and the outcome.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 2rem;">
        <a href="#allstar" class="btn btn--outline">All Star Lake Spa</a>
        <a href="#cascadepest" class="btn btn--outline">Cascade Pest Control</a>
        <a href="#montessori" class="btn btn--outline">NW Montessori School</a>
        <a href="#marcel" class="btn btn--outline">Marcel Dolak — E&V</a>
      </div>
    </div>
  </section>

  <!-- ALL STAR -->
  <section id="allstar">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Website Redesign</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Bellevue, WA · ~7 days</span>
        </div>
        <h2>All Star Lake Spa — <em>Website Redesign</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Redesign</span>
          <span class="tag tag--accent">Copy</span>
          <span class="tag tag--accent">Spam Removal</span>
          <span class="tag tag--accent">Mobile</span>
          <span class="tag tag--accent">SEO</span>
        </div>

        <div class="ba-slider" id="ba-slider-cs" style="margin: 2rem 0;">
          <img src="/img/allstar-before.jpg" alt="Before" class="ba-before" />
          <img src="/img/allstar-after.jpg" alt="After" class="ba-after" />
          <div class="ba-handle" id="ba-handle-cs"></div>
        </div>

        <h3>The Situation</h3>
        <p style="color: var(--text-muted);">All Star Massage and Spa — 18+ years in business with a strong reputation, but a website that had fallen far behind. Cluttered homepage, broken mobile experience, and injected spam content actively harming their image.</p>
        <h3 style="margin-top: 1.5rem;">What I Did</h3>
        <ul class="checklist" style="margin-top: 0.75rem;">
          <li>Removed injected spam content from the services page</li>
          <li>Rewrote homepage headline and intro copy</li>
          <li>Restructured and simplified the services section</li>
          <li>Improved CTAs and booking flow</li>
          <li>Fixed mobile layout — tap targets, text sizing, spacing</li>
          <li>Visual redesign to match actual quality of the business</li>
          <li>Google Business alignment check</li>
        </ul>
        <div class="stats">
          <div class="stat"><span class="stat-value">100%</span><span class="stat-label">Spam Removed</span></div>
          <div class="stat"><span class="stat-value">New</span><span class="stat-label">Homepage Copy</span></div>
          <div class="stat"><span class="stat-value">Mobile</span><span class="stat-label">Fully Responsive</span></div>
        </div>
        <div class="testimonial">
          <blockquote>"The site finally reflects the quality of what we actually offer. Patients are finding us more easily and the booking flow actually works now."</blockquote>
          <cite>— Starla Schwartz, Owner · All Star Massage and Spa</cite>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width: var(--max-width-narrow); margin: 0 auto;"></div>

  <!-- CASCADE PEST -->
  <section id="cascadepest">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Video + Content Production</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Western Washington</span>
        </div>
        <h2>Cascade Pest Control — <em>Ongoing Content</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Brand Video</span>
          <span class="tag tag--accent">Social Reels</span>
          <span class="tag tag--accent">Commercials</span>
          <span class="tag tag--accent">Seasonal Campaigns</span>
        </div>
        <h3 style="margin-top: 2rem;">The Work</h3>
        <p style="color: var(--text-muted);">Ongoing content partnership — commercials, social reels, seasonal campaign videos, and YouTube content. I handle concept, scripting, filming, editing, and multi-format delivery across all platforms.</p>
        <div class="case-images">
          <img src="/img/cascade-pest-case.jpg" alt="Cascade Pest Control" loading="lazy" />
          <img src="/img/cascade-pest-still-2.jpg" alt="On-location" loading="lazy" />
          <img src="/img/cascade-pest-still-3.jpg" alt="Social content" loading="lazy" />
        </div>
        <div class="testimonial">
          <blockquote>"Cascade Pest Control has partnered with Cascade Creatives on numerous video projects over the past few years. Jeremy always seeks to understand our vision to provide us with the best possible product."</blockquote>
          <cite>— Kevin Peterson, Operations Manager · Cascade Pest Control</cite>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width: var(--max-width-narrow); margin: 0 auto;"></div>

  <!-- NW MONTESSORI -->
  <section id="montessori">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Creative Direction + Film</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Seattle, WA</span>
        </div>
        <h2>NW Montessori School — <em>60th Anniversary</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Anniversary Film</span>
          <span class="tag tag--accent">Creative Direction</span>
          <span class="tag tag--accent">Interviews</span>
          <span class="tag tag--accent">Fundraiser Screening</span>
        </div>
        <h3 style="margin-top: 2rem;">The Project</h3>
        <p style="color: var(--text-muted);">A 90-second cinematic teaser for their 60th anniversary fundraiser — weaving archival footage, phone-recorded reflections, and key leadership interviews into a story built around legacy, community, and future.</p>
        <div class="case-images">
          <img src="/img/montessori-still-1.jpg" alt="NW Montessori" loading="lazy" />
          <img src="/img/montessori-still-2.jpg" alt="Archival footage" loading="lazy" />
          <img src="/img/montessori-still-3.jpg" alt="Community" loading="lazy" />
        </div>
        <div class="testimonial">
          <blockquote>"Jeremy and Melissa understood what we were trying to capture — not just our history, but the feeling of what this school means to our community. The film brought the room to tears at the fundraiser."</blockquote>
          <cite>— Elizabeth Truman, Head of School · NW Montessori School</cite>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width: var(--max-width-narrow); margin: 0 auto;"></div>

  <!-- MARCEL -->
  <section id="marcel">
    <div class="container container--narrow">
      <div class="reveal">
        <div class="case-header">
          <span class="label">Real Estate Video + Drone</span>
          <span>·</span>
          <span style="font-size: 0.8rem; color: var(--text-dim);">Kirkland / Eastside / Seattle</span>
        </div>
        <h2>Marcel Dolak — <em>Engel & Völkers</em></h2>
        <div class="tags" style="margin: 1rem 0;">
          <span class="tag tag--accent">Listing Videos</span>
          <span class="tag tag--accent">Drone</span>
          <span class="tag tag--accent">Cinematic</span>
          <span class="tag tag--accent">Luxury</span>
        </div>
        <h3 style="margin-top: 2rem;">The Partnership</h3>
        <p style="color: var(--text-muted);">Cinematic listing videos for luxury properties — smooth walkthroughs, aerial drone coverage, and cinematic establishing shots, all edited to a luxury standard. Properties across Medina, Bellevue, Kirkland, Magnolia, and the broader Eastside.</p>
        <div class="testimonial">
          <blockquote>"Jeremy's listing videos consistently stand out. The aerial coverage and cinematic quality give my clients confidence and give buyers a reason to schedule a showing."</blockquote>
          <cite>— Marcel Dolak, Engel & Völkers Kirkland</cite>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-block" style="background: var(--bg-elevated);">
    <div class="container">
      <h2 class="reveal">Ready for results like <em>these?</em></h2>
      <p style="color: var(--text-muted); margin-bottom: 2rem;" class="reveal">Tell me about your project. I'll tell you exactly what I'd do and what it would cost.</p>
      <a href="/contact" class="btn btn--primary reveal">Start a Project</a>
    </div>
  </section>

  <script>
    const slider = document.getElementById('ba-slider-cs');
    const handle = document.getElementById('ba-handle-cs');
    if (slider && handle) {
      let d = false;
      const m = (x: number) => { const r = slider.getBoundingClientRect(); let p = ((x - r.left) / r.width) * 100; p = Math.max(5, Math.min(95, p)); handle.style.left = p + '%'; const a = slider.querySelector('.ba-after') as HTMLElement; if (a) a.style.clipPath = `inset(0 0 0 ${p}%)`; };
      slider.addEventListener('mousedown', (e) => { d = true; m(e.clientX); });
      window.addEventListener('mousemove', (e) => { if (d) m(e.clientX); });
      window.addEventListener('mouseup', () => { d = false; });
      slider.addEventListener('touchstart', (e) => { d = true; m(e.touches[0].clientX); }, { passive: false });
      slider.addEventListener('touchmove', (e) => { if (d) { e.preventDefault(); m(e.touches[0].clientX); } }, { passive: false });
      slider.addEventListener('touchend', () => { d = false; });
    }
  </script>
</Base>
