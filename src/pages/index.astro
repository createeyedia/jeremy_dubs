---
import BaseLayout from '../layouts/BaseLayout.astro';
import CatMascot from '../components/CatMascot.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
---

<BaseLayout title="Web Design & Content for Businesses | Cascade Creatives">

<!-- ═══ HERO ═══ -->
<section class="home-hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-cat-mobile">
        <CatMascot id="M" size={56} />
      </div>
      <div class="hero-badge animate-in"><span class="dot"></span>Design studio &middot; Production team &middot; One engagement</div>
      <h1 class="animate-in delay-1">Your business deserves a website that actually <em>wins you customers.</em></h1>
      <p class="hero-sub animate-in delay-2">Cascade Creatives builds modern websites, shoots the content that goes on them, and handles the strategy behind both &mdash; so your business looks as good online as it is in person. One team. One point of contact. Done in weeks, not months.</p>
      <div class="hero-actions animate-in delay-3">
        <a href="/contact" class="btn btn-primary">Start a Project &rarr;</a>
        <a href="/work" class="btn btn-ghost">See Our Work</a>
      </div>
    </div>
    <div class="hero-cat" aria-hidden="true">
      <CatMascot id="H" size={440} />
    </div>
  </div>
</section>

<!-- ═══ MARQUEE — tightened to three pillars ═══ -->
<div class="marquee-wrap">
  <div class="marquee-track">
    {[...Array(4)].flatMap(() => ['Web Design','Visual Content','Digital Strategy']).map(s => (
      <><span>{s}</span><span class="sep"></span></>
    ))}
  </div>
</div>

<!-- ═══ TRUST STRIP ═══ -->
<div class="trust-strip">
  <div class="container">
    <p>10+ years in production &middot; 50+ projects delivered &middot; Bellingham, WA &middot; Serving Whatcom &amp; Skagit County</p>
  </div>
</div>

<!-- ═══ WHAT WE DO ═══ -->
<section class="reveal">
  <div class="container">
    <p class="section-label">What We Do</p>
    <h2 class="section-title">Website, content, and strategy &mdash;<br /><em>from one team, on one invoice.</em></h2>
    <p class="section-sub">Most businesses hire a web designer, then a photographer, then a marketing person. We do all three &mdash; which means everything works together from day one.</p>
    <div class="services-grid">
      <div class="card">
        <p class="card-label">Websites</p>
        <h3>Websites built to convert.</h3>
        <p>Custom-designed, fast-loading, and built for the way people actually find and hire businesses online. Most sites launch in 2&ndash;3 weeks. Starting at $1,200.</p>
        <div class="card-tags"><span>Custom design</span><span>Fast-loading</span><span>SEO-ready</span><span>Mobile-first</span></div>
      </div>
      <div class="card">
        <p class="card-label">Content</p>
        <h3>Original photos, video, and drone &mdash; not stock.</h3>
        <p>We shoot the visuals your site, ads, and Google listing actually need. Real content builds trust faster than anything templated ever will.</p>
        <div class="card-tags"><span>Video</span><span>Photography</span><span>Drone</span><span>Social content</span></div>
      </div>
      <div class="card">
        <p class="card-label">Strategy</p>
        <h3>A clear plan before we build anything.</h3>
        <p>We audit your website, Google Business profile, and online presence &mdash; then tell you exactly what to fix, what to build, and what to skip.</p>
        <div class="card-tags"><span>Website audit</span><span>Google Business</span><span>Online presence review</span><span>Growth roadmap</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ DIFFERENTIATOR ═══ -->
<section class="differentiator reveal">
  <div class="container">
    <h2 class="section-title">One team handles your website and your content. <em>That&rsquo;s the whole point.</em></h2>
    <p class="section-sub">Most businesses hire a web designer who asks for photos they don&rsquo;t have, then a photographer who doesn&rsquo;t know what the site needs. The result is a site full of stock images &mdash; or a six-month timeline while everyone gets on the same page. We handle both, so your site launches with real content, on time, and looking like a business that has its act together.</p>
  </div>
</section>

<!-- ═══ PORTFOLIO ═══ -->
<section class="reveal">
  <div class="container">
    <p class="section-label">Portfolio</p>
    <h2 class="section-title">Real projects. <em>Real results.</em></h2>

    <!-- Before/After Sliders -->
    <div class="slider-grid">
      <div>
        <BeforeAfter before="/img/allstar-before.jpg" after="/img/allstar-after.jpg" alt="All Star Lake Spa" />
        <p style="font-family:var(--font-display);font-size:1.1rem;color:#fff;margin-top:12px">All Star Lake Spa <span style="font-size:.7rem;color:var(--accent);letter-spacing:.1em;text-transform:uppercase;margin-left:8px">Redesign</span></p>
        <p style="font-size:.82rem;color:var(--text-muted);margin-top:4px;line-height:1.5">Spam-injected site with broken mobile layout. Rebuilt in 7 days with clean design, rewritten copy, and working booking flow. Booking flow now works on mobile. Owner stopped losing walk-in leads from search.</p>
      </div>
      <div>
        <BeforeAfter before="/img/paradise-finance-before.jpg" after="/img/paradise-finance-thumb.jpg" alt="Paradise Finance" />
        <p style="font-family:var(--font-display);font-size:1.1rem;color:#fff;margin-top:12px">Paradise Finance <span style="font-size:.7rem;color:var(--accent);letter-spacing:.1em;text-transform:uppercase;margin-left:8px">Redesign</span></p>
        <p style="font-size:.82rem;color:var(--text-muted);margin-top:4px;line-height:1.5">Replaced a 2001-era site with a modern, fast-loading presence. Site now loads in under 2 seconds and matches the credibility of a 28-year-old firm.</p>
      </div>
    </div>

    <!-- Video portfolio with business-context captions -->
    <div class="portfolio-grid" style="margin-top:24px">
      {[
        ['/img/cascade-pest-case.jpg','Video · Website & Ads','Cascade Pest Control', '278099968'],
        ['https://vumbnail.com/316959450.jpg','Video · Hospitality','Silver Cloud Hotels', '316959450'],
        ['/img/montessori-still-1.jpg','Video · Enrollment','NW Montessori', '1080296239'],
        ['https://vumbnail.com/851990318.jpg','Drone · Luxury Residential','Medina Real Estate', '851990318'],
        ['https://vumbnail.com/287757023.jpg','Video · Residential','Bellevue Towers', '287757023'],
        ['https://vumbnail.com/75112064.jpg','Brand Film · Outerwear','686 — Lights Out', '75112064'],
      ].map(([src, type, name, vimeoId]) => (
        <div class={`portfolio-item ${vimeoId ? 'has-video' : ''}`} data-vimeo={vimeoId || ''}>
          <img src={src as string} alt={name as string} loading="lazy" />
          <div class="portfolio-overlay">
            <p class="type">{type}</p>
            <p class="name">{name}</p>
          </div>
          {vimeoId && (
            <button class="play-btn" aria-label={`Play ${name}`}>
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="23" stroke="#c8ff00" stroke-width="2" fill="rgba(0,0,0,0.5)" />
                <polygon points="19,14 36,24 19,34" fill="#c8ff00" />
              </svg>
            </button>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ HOW WE WORK ═══ -->
<section class="reveal">
  <div class="container">
    <p class="section-label">How We Work</p>
    <h2 class="section-title">Less process. More <em>progress.</em></h2>
    <div class="process-grid">
      {[
        ['01','We produce your content too.','Already have photos and video? We integrate them. Need new content? We shoot it. Either way, your site goes live with real visuals — not placeholders.'],
        ['02','You talk to the people doing the work.','No account managers. No layers. You work directly with the team building your site.'],
        ['03','Faster timelines. Same quality.','We use modern tools — including AI where it genuinely helps — to move through research, planning, and development faster. You get a better site in less time, without the inflated timeline or invoice.'],
        ['04','Tight scope. Fast delivery. No surprises.','We tell you what\'s included, what it costs, and when it ships — before we start. Most sites launch in 2–3 weeks.'],
      ].map(([num, title, desc]) => (
        <div class="process-step">
          <span class="process-num">{num}</span>
          <div><h3>{title}</h3><p>{desc}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIALS ═══ -->
<div class="testimonials reveal">
  <div class="container">
    <p class="section-label" style="text-align:center;margin-bottom:40px">What Clients Say</p>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <img src="/img/cascade-pest-logo.png" alt="Cascade Pest Control" class="testimonial-logo" />
        <blockquote>&ldquo;Jeremy always seeks to understand our vision to provide us with the best possible product.&rdquo;</blockquote>
        <cite>&mdash; Kevin Peterson, Operations Manager &middot; Cascade Pest Control</cite>
      </div>
      <div class="testimonial-card">
        <img src="/img/engel-volkers-logo.png" alt="Engel &amp; Völkers" class="testimonial-logo" />
        <blockquote>&ldquo;Jeremy&rsquo;s video work has been a game changer for my marketing. He consistently delivers high quality aerial video and photography. My clients have come to know the quality and it is recognized as part of my high standard of service.&rdquo;</blockquote>
        <cite>&mdash; Marcel Dolak, Realtor &middot; Engel &amp; V&ouml;lkers Kirkland</cite>
      </div>
    </div>
  </div>
</div>

<!-- ═══ PRICING STRIP ═══ -->
<div class="pricing-strip reveal">
  <div class="container" style="text-align:center">
    <p class="pricing-strip-text">Most websites: <strong>$1,200&ndash;$3,500.</strong> Most timelines: <strong>2&ndash;3 weeks.</strong> No retainers. No surprises.</p>
  </div>
</div>

<!-- ═══ FINAL CTA ═══ -->
<section class="cta-section reveal">
  <div class="container">
    <p class="section-label">Ready?</p>
    <h2 class="section-title">Let&rsquo;s figure out what your business <em>actually needs.</em></h2>
    <p class="section-sub">Tell us what you&rsquo;re working with. We&rsquo;ll come back with a clear plan, an honest price, and a timeline you can hold us to.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:8px">
      <a href="/contact" class="btn btn-primary">Start a Conversation &rarr;</a>
      <a href="tel:3603186052" class="btn btn-ghost">(360) 318-6052</a>
    </div>
  </div>
</section>

</BaseLayout>
