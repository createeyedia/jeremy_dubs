const expectations = [
  { num: '01', title: 'You Work Directly With Me', desc: 'No project managers or account reps. You talk to the person doing the work, start to finish.' },
  { num: '02', title: 'Specific, Not Vague', desc: "I tell you exactly what's wrong and exactly what I'd fix — no fluff, no selling you things you don't need." },
  { num: '03', title: 'Video + Web Under One Roof', desc: "Most web people can't shoot. Most videographers can't improve a website. I do both — so your content and your site actually work together." },
