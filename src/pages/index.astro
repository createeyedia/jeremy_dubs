---
import BaseLayout from '../layouts/BaseLayout.astro';
import CatMascot from '../components/CatMascot.astro';

const pestLogoUrl = '/img/cascade-pest-logo.png';
---

<BaseLayout title="Cascade Creatives — Web Design, Content Production & Digital Strategy">

<section class="home-hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge animate-in"><span class="dot"></span>Design studio &middot; Production team &middot; One engagement</div>
      <h1 class="animate-in delay-1">Most businesses have a website.<br />Very few have one that <em>works.</em></h1>
      <p class="hero-sub animate-in delay-2">We design websites that convert, produce the content that goes on them, and handle the strategy behind both. No agency layers. No six-month timelines.</p>
      <div class="hero-actions animate-in delay-3">
        <a href="/contact" class="btn btn-primary">Let&rsquo;s Talk &rarr;</a>
        <a href="/work" class="btn btn-ghost">See What We&rsquo;ve Built</a>
      </div>
    </div>
  </div>
  <div class="hero-cat" aria-hidden="true">
    <CatMascot id="H" size={440} />
  </div>
</section>

<div class="trusted">
  <div class="container">
    <p class="trusted-label">Trusted by</p>
    <div class="trusted-logos">
      <span>Paradise Finance</span>
      <span>All Star Lake Spa</span>
      <span>Cascade Pest Control</span>
      <span>Engel &amp; V&ouml;lkers</span>
    </div>
  </div>
</div>

<div class="marquee-wrap">
  <div class="marquee-track">
    {['Web Design','Content Production','Social & Paid Ads','SEO','Video & Drone','Website Redesigns','Digital Strategy'].map(s => [s,s]).flat().map(s => (
      <><span>{s}</span><span class="sep"></span></>
    ))}
  </div>
</div>

<section class="reveal">
  <div class="container">
    <p class="section-label">What We Do</p>
    <h2 class="section-title">Design, content, and strategy &mdash;<br /><em>without the overhead.</em></h2>
    <p class="section-sub">Most agencies separate these into three departments and three invoices. We handle all of it as one team, in one engagement.</p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px">
      <div class="card">
        <p class="card-label">Primary</p>
        <h3>Websites that actually perform.</h3>
        <p>Custom-built for speed, clarity, and conversion. New builds ship in 2&ndash;3 weeks.</p>
        <div class="card-tags"><span>Custom design</span><span>Astro / Static</span><span>SEO</span><span>Performance</span></div>
      </div>
      <div class="card">
        <p class="card-label">Integrated</p>
        <h3>Real content. Not stock photos.</h3>
        <p>We shoot original photo, video, and drone content &mdash; built for your site, your ads, and your brand.</p>
        <div class="card-tags"><span>Video</span><span>Photography</span><span>Drone (FAA 107)</span><span>Social</span></div>
      </div>
      <div class="card">
        <p class="card-label">Strategic</p>
        <h3>Smarter workflows. Faster output.</h3>
        <p>Practical AI integration for content creation, development, and operations.</p>
        <div class="card-tags"><span>AI integration</span><span>Workflow</span><span>Content systems</span><span>Audit</span></div>
      </div>
    </div>
  </div>
</section>

<section class="reveal">
  <div class="container">
    <p class="section-label">Portfolio</p>
    <h2 class="section-title">Recent work across web, video, and <em>content.</em></h2>
    <div class="portfolio-grid">
      {[
        ['/img/paradise-finance-thumb.jpg','Website Design','Paradise Finance'],
        ['/img/allstar-after.jpg','Website Redesign','All Star Lake Spa'],
        ['/img/cascade-pest-case.jpg','Video + Content','Cascade Pest Control'],
        ['https://vumbnail.com/316959450.jpg','Commercial','Silver Cloud Hotels'],
        ['/img/montessori-still-1.jpg','Brand Film','NW Montessori'],
        ['https://vumbnail.com/851990318.jpg','Drone & Aerial','Medina Real Estate'],
      ].map(([src, type, name]) => (
        <div class="portfolio-item">
          <img src={src} alt={name} loading="lazy" />
          <div class="portfolio-overlay">
            <p class="type">{type}</p>
            <p class="name">{name}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="reveal">
  <div class="container">
    <p class="section-label">How We Work</p>
    <h2 class="section-title">Less process. More <em>output.</em></h2>
    <div class="process-grid">
      {[
        ['01','We produce your content too.','Most web designers hand you a Figma file and say "add your photos." We shoot the photos. We produce the video. Your site goes live with real content.'],
        ['02','You talk to the people doing the work.','No account managers. No layers. You work directly with the team building your site.'],
        ['03','We use AI to move faster, not cut corners.','AI is part of how we work — research, development, content systems. Your project ships faster without sacrificing quality.'],
        ['04','Tight scope. Fast delivery. No surprises.','We tell you what\'s included, what it costs, and when it ships — before we start. Most sites launch in 2–3 weeks.'],
      ].map(([num, title, desc]) => (
        <div class="process-step">
          <span class="process-num">{num}</span>
          <div><h3>{title}</h3><p>{desc}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="testimonial reveal">
  <div class="container">
    <div class="testimonial-logo">
      <img src={pestLogoUrl} alt="Cascade Pest Control" />
    </div>
    <blockquote>&ldquo;Jeremy always seeks to understand our vision to provide us with the best possible product.&rdquo;</blockquote>
    <cite>&mdash; Kevin Peterson, Operations Manager &middot; Cascade Pest Control</cite>
  </div>
</div>

<section class="cta-section reveal">
  <div class="container">
    <p class="section-label">Ready?</p>
    <h2 class="section-title">Let&rsquo;s figure out what your business <em>actually needs.</em></h2>
    <p class="section-sub">Tell us what you&rsquo;re working on. We&rsquo;ll come back with a clear plan, an honest price, and a timeline you can hold us to.</p>
    <a href="/contact" class="btn btn-primary">Start a Conversation &rarr;</a>
  </div>
</section>

</BaseLayout>
