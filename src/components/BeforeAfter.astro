---
interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
  alt?: string;
}

const { before, after, beforeLabel = 'Before', afterLabel = 'After', alt = '' } = Astro.props;
---

<div class="ba-slider" data-ba-slider>
  <div class="ba-after">
    <img src={after} alt={`${alt} — After`} loading="lazy" />
  </div>
  <div class="ba-before">
    <img src={before} alt={`${alt} — Before`} loading="lazy" />
  </div>
  <div class="ba-handle">
    <div class="ba-line"></div>
    <div class="ba-knob">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M8 5l-5 7 5 7M16 5l5 7-5 7" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="ba-line"></div>
  </div>
  <span class="ba-tag ba-tag-before">{beforeLabel}</span>
  <span class="ba-tag ba-tag-after">{afterLabel}</span>
</div>

<style>
  .ba-slider { position: relative; overflow: hidden; border-radius: 12px; aspect-ratio: 4/3; cursor: col-resize; touch-action: none; -webkit-user-select: none; user-select: none; }
  .ba-slider::after { content: ''; position: absolute; top: 0; bottom: 0; left: calc(50% - 24px); width: 48px; z-index: 15; cursor: col-resize; }
  .ba-slider.dragging { cursor: col-resize; } .ba-slider.dragging::after { left: 0; width: 100%; }
  .ba-after, .ba-before { position: absolute; inset: 0; }
  .ba-after img, .ba-before img { width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none; }
  .ba-before { clip-path: inset(0 50% 0 0); }
  .ba-handle { position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; z-index: 10; pointer-events: none; transition: none; }
  .ba-line { flex: 1; width: 2px; background: #c8ff00; box-shadow: 0 0 6px rgba(200, 255, 0, 0.3); }
  .ba-knob { width: 40px; height: 40px; border-radius: 50%; background: #c8ff00; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 2px 10px rgba(200, 255, 0, 0.25); transition: transform 0.15s ease; }
  .ba-slider.dragging .ba-knob { transform: scale(1.15); }
  .ba-tag { position: absolute; bottom: 10px; font-size: 0.55rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; z-index: 5; border: 1px solid rgba(255,255,255,0.1); }
  .ba-tag-before { left: 10px; background: #0a0a0a; color: #ff6b9d; }
  .ba-tag-after { right: 10px; background: #0a0a0a; color: #c8ff00; }
  @media (max-width: 768px) { .ba-tag { font-size: 0.5rem; padding: 3px 8px; bottom: 8px; } }
</style>

<script>
  function initSliders() {
    document.querySelectorAll('[data-ba-slider]').forEach((slider) => {
      if ((slider as any)._baInit) return; (slider as any)._baInit = true;
      const before = slider.querySelector('.ba-before') as HTMLElement;
      const handle = slider.querySelector('.ba-handle') as HTMLElement;
      if (!before || !handle) return;
      let active = false;
      function update(x: number) { const rect = slider.getBoundingClientRect(); let pct = ((x - rect.left) / rect.width) * 100; pct = Math.max(2, Math.min(98, pct)); before.style.clipPath = `inset(0 ${100 - pct}% 0 0)`; handle.style.left = `${pct}%`; (slider as HTMLElement).style.setProperty('--handle-pos', `${pct}%`); }
      function startDrag(x: number) { active = true; slider.classList.add('dragging'); update(x); }
      function endDrag() { active = false; slider.classList.remove('dragging'); }
      slider.addEventListener('mousedown', (e: Event) => { e.preventDefault(); startDrag((e as MouseEvent).clientX); });
      window.addEventListener('mousemove', (e: Event) => { if (active) { e.preventDefault(); update((e as MouseEvent).clientX); } });
      window.addEventListener('mouseup', endDrag);
      slider.addEventListener('touchstart', (e: Event) => { e.preventDefault(); startDrag((e as TouchEvent).touches[0].clientX); }, { passive: false });
      window.addEventListener('touchmove', (e: Event) => { if (active) { e.preventDefault(); update((e as TouchEvent).touches[0].clientX); } }, { passive: false });
      window.addEventListener('touchend', endDrag);
    });
  }
  initSliders();
  document.addEventListener('astro:after-swap', initSliders);
</script>
