---
interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
  alt?: string;
}

const { before, after, beforeLabel = 'Before', afterLabel = 'After', alt = '' } = Astro.props;
---

<div class="ba-slider" data-ba-slider>
  <div class="ba-after">
    <img src={after} alt={`${alt} — After`} loading="lazy" />
  </div>
  <div class="ba-before">
    <img src={before} alt={`${alt} — Before`} loading="lazy" />
  </div>
  <div class="ba-handle">
    <div class="ba-handle-line"></div>
    <div class="ba-handle-knob">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M8 5l-5 7 5 7M16 5l5 7-5 7" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="ba-handle-line"></div>
  </div>
  <span class="ba-label ba-label-before">{beforeLabel}</span>
  <span class="ba-label ba-label-after">{afterLabel}</span>
</div>

<style>
  .ba-slider {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    aspect-ratio: 4/3;
    cursor: ew-resize;
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
  }
  .ba-after, .ba-before {
    position: absolute;
    inset: 0;
  }
  .ba-after img, .ba-before img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ba-before {
    clip-path: inset(0 50% 0 0);
  }
  .ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
    pointer-events: none;
  }
  .ba-handle-line {
    flex: 1;
    width: 3px;
    background: #c8ff00;
    box-shadow: 0 0 8px rgba(200, 255, 0, 0.4);
  }
  .ba-handle-knob {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #c8ff00;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 2px 12px rgba(200, 255, 0, 0.3);
  }
  .ba-label {
    position: absolute;
    top: 16px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    z-index: 5;
  }
  .ba-label-before {
    left: 16px;
    background: rgba(0, 0, 0, 0.6);
    color: #ff6b9d;
    backdrop-filter: blur(8px);
  }
  .ba-label-after {
    right: 16px;
    background: rgba(0, 0, 0, 0.6);
    color: #c8ff00;
    backdrop-filter: blur(8px);
  }
</style>

<script>
  document.querySelectorAll('[data-ba-slider]').forEach((slider) => {
    const before = slider.querySelector('.ba-before') as HTMLElement;
    const handle = slider.querySelector('.ba-handle') as HTMLElement;
    if (!before || !handle) return;

    let active = false;

    function update(x: number) {
      const rect = slider.getBoundingClientRect();
      let pct = ((x - rect.left) / rect.width) * 100;
      pct = Math.max(2, Math.min(98, pct));
      before.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      handle.style.left = `${pct}%`;
    }

    slider.addEventListener('mousedown', (e: Event) => {
      active = true;
      update((e as MouseEvent).clientX);
    });
    window.addEventListener('mousemove', (e: Event) => {
      if (active) update((e as MouseEvent).clientX);
    });
    window.addEventListener('mouseup', () => { active = false; });

    slider.addEventListener('touchstart', (e: Event) => {
      active = true;
      e.preventDefault();
      update((e as TouchEvent).touches[0].clientX);
    }, { passive: false });
    window.addEventListener('touchmove', (e: Event) => {
      if (active) {
        e.preventDefault();
        update((e as TouchEvent).touches[0].clientX);
      }
    }, { passive: false });
    window.addEventListener('touchend', () => { active = false; });
  });
</script>
