---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  active?: string;
  description?: string;
}

const {
  title,
  active = '',
  description = 'Cascade Creatives — Web design, content production, and digital strategy for businesses ready to show up better online.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://cascadecreatives.com/img/og-image.png" />
  <meta property="og:url" content="https://cascadecreatives.com" />
  <meta property="og:site_name" content="Cascade Creatives" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://cascadecreatives.com/img/og-image.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body>
  <Nav active={active} />
  <main transition:animate="fade"><slot /></main>
  <Footer />
  <script>
    function initReveal() { document.querySelectorAll('.reveal').forEach((el) => { new IntersectionObserver((entries, obs) => { entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }); }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }).observe(el); }); }
    initReveal(); document.addEventListener('astro:after-swap', initReveal);
    function initVideoPlayers() { document.querySelectorAll('.portfolio-item.has-video').forEach((item) => { if ((item as any)._videoInit) return; (item as any)._videoInit = true; const vimeoId = item.getAttribute('data-vimeo'); if (!vimeoId) return; item.addEventListener('click', () => { if (item.classList.contains('playing')) return; const embed = document.createElement('div'); embed.className = 'video-embed'; embed.innerHTML = `<iframe src="https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0&color=c8ff00" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>`; item.appendChild(embed); item.classList.add('playing'); }); }); }
    initVideoPlayers(); document.addEventListener('astro:after-swap', initVideoPlayers);
  </script>
</body>
</html>
